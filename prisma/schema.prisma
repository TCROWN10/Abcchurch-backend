// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum DonationType {
  TITHE
  OFFERING
  DONATION
}

enum MessageType {
  SUNDAY
  WEEKDAY
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PrayerRequestStatus {
  PENDING
  READ
  ARCHIVED
}

model User {
  id              Int          @id @default(autoincrement())
  email           String       @unique
  password        String?      @db.VarChar(1000)
  googleId        String?      @unique
  isEmailVerified Boolean      @default(false)
  role            UserRole     @default(USER)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  detailsId       Int?         @unique
  details         UserDetails? @relation(fields: [detailsId], references: [id])

  // Relations
  donations               Donation[]
  messages                Message[]
  newsletterSubscriptions NewsletterSubscription[]
  prayerRequests          PrayerRequest[]
  emailLogs               EmailLog[]
  refreshTokens           RefreshToken[]
  otpCodes                OtpCode[]

  @@index([email])
  @@index([googleId])
  @@index([role])
}

model UserDetails {
  id             Int       @id @default(autoincrement())
  name           String?
  lastName       String?
  phoneNumber    String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  profilePicture String?
  gender         String?
  dob            DateTime?
  birthdayWished Boolean   @default(false) // Track if birthday wish has been sent today
  birthdayWishedAt DateTime? // Track when birthday was wished
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  User           User?
}

// Outbox Pattern for Event-Driven Architecture
model Outbox {
  id           String       @id @default(uuid())
  eventType    String
  payload      Json
  status       OutboxStatus @default(PENDING)
  retryCount   Int          @default(0)
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Donations, Tithes, and Offerings
model Donation {
  id              String       @id @default(uuid())
  userId          Int
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            DonationType
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("USD")
  stripePaymentId String?      @unique
  stripeSessionId String?
  description     String?
  isRecurring     Boolean      @default(false)
  recurringPeriod String? // monthly, weekly, etc.
  status          String       @default("pending") // pending, completed, failed
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([stripePaymentId])
}

// Messages (Sunday/Weekday)
model Message {
  id          String      @id @default(uuid())
  title       String
  content     String      @db.Text
  type        MessageType
  authorId    Int?
  author      User?       @relation(fields: [authorId], references: [id])
  videoUrl    String?
  audioUrl    String?
  imageUrl    String?
  attachments Json?
  isPublished Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([createdAt])
}

// Newsletter Subscriptions
model NewsletterSubscription {
  id             Int       @id @default(autoincrement())
  userId         Int?
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email          String
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  preferences    Json? // { messageUpdates: true, newsUpdates: true, etc. }

  @@unique([email])
  @@index([email])
  @@index([isActive])
  @@index([userId])
}

// Prayer Requests
model PrayerRequest {
  id             String              @id @default(uuid())
  userId         Int?
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  requesterName  String
  requesterEmail String?
  title          String
  content        String              @db.Text
  status         PrayerRequestStatus @default(PENDING)
  isPublic       Boolean             @default(false)
  readBy         Json? // Array of admin IDs who read it
  readAt         DateTime?
  notes          String?             @db.Text // Admin notes
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([isPublic])
  @@index([createdAt])
  @@index([userId])
}

// Email Logs (for tracking sent emails)
model EmailLog {
  id               String    @id @default(uuid())
  userId           Int?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  recipientEmail   String
  subject          String
  emailType        String // birthday, newsletter, message_update, etc.
  status           String // sent, failed, pending
  mailjetMessageId String?
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([emailType])
  @@index([status])
  @@index([createdAt])
}

// Refresh Tokens
model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// OTP Codes for Email Verification
model OtpCode {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
  @@index([used])
}
